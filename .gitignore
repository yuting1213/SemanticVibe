# Environments
.env
.venv/
venv/
.python-version.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Project data (rebuild via data/README.md)
data/assets_lib/*.png
data/assets_lib/*.jpg
data/assets_lib/_procedural_backup/
data/test_videos/*.mp4
data/test_videos/*.mov
data/fonts/*.ttf
data/fonts/*.otf
outputs/

# v5 sample inputs — videos are gitignored (large), lyric JSONs commit normally.
samples/*.mp4
samples/*.mov

# SDXL / Z-Image-generated stickers (rebuild via scripts/generate_stickers.py).
# `assets/*` (not `assets/`) so the !-negations below can re-include
# specific config files inside the directory.
assets/*
!assets/tag_vocabulary.json
!assets/styles.json
!assets/gesture_vocabulary.json
loras/
failed.log

# Asset upload zips (250MB+ each, regenerated from source)
assets-*.zip
.tofu_filelist.txt
.cache/

# v11 Hyperframes Node workspace — node_modules is huge (~200 MB) and
# can be regenerated with `cd playground/hf_workspace && npm install`.
playground/hf_workspace/node_modules/

# Stray MoviePy TEMP files (from interrupted moviepy renders)
*TEMP_MPY_*.mp4

# Models / caches
models/
*.bin
*.safetensors

# IDE
.idea/
.vscode/
.claude/
*.swp

# Notebooks (cell outputs are stripped via nbstripout, but keep this as a safety net)
.ipynb_checkpoints/

# OS
Thumbs.db
.DS_Store
