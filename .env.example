# Copy to `.env` and fill in. `.env` is gitignored.

# ---- LLM provider selection ----
# One of: claude, openai
SEMANTICVIBE_LLM_PROVIDER=claude

# Cost mode. dev = Haiku/gpt-4o-mini (~1/20 prod cost). prod = Sonnet/gpt-4o.
SEMANTICVIBE_COST_MODE=dev

# ---- API keys (lab-shared keys; do not commit) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Per-call cost ceiling (USD). Hard-fails if estimated cost exceeds. ----
SEMANTICVIBE_COST_CEILING_USD=0.50

# ---- Paths ----
SEMANTICVIBE_DATA_DIR=data
SEMANTICVIBE_OUTPUT_DIR=outputs
