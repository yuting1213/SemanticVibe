{
  "_comment": "v14 closed gesture vocabulary. `tag` and `animation` semantics unchanged from v13.1. NEW: `anchor_landmark` chooses where to position the decoration relative to the body — the renderer maps the symbol to a MediaPipe landmark (or pair, averaged) and places the decoration there. Symbols: right_index/left_index (finger tip), right_wrist/left_wrist, mid_wrists, mid_wrists_above (above the hands), mid_shoulders, mid_shoulders_below, right_eye_offset (beside the face, NOT on it).",
  "fallback_gesture": "none",
  "gestures": [
    {"id": "heart_hands",     "tag": "heart",      "animation": "scale_pop",      "anchor_landmark": "mid_wrists"},
    {"id": "smile_close_up",  "tag": "flower",     "animation": "scale_pop",      "anchor_landmark": "right_eye_offset"},
    {"id": "peace_sign",      "tag": "star",       "animation": "spin_in",        "anchor_landmark": "right_index"},
    {"id": "arms_raised",     "tag": "burst",      "animation": "drop_in",        "anchor_landmark": "mid_wrists_above"},
    {"id": "jump",            "tag": "lightning",  "animation": "stamp",          "anchor_landmark": "mid_shoulders_below"},
    {"id": "spin",            "tag": "music_note", "animation": "spin_in",        "anchor_landmark": "mid_shoulders"},
    {"id": "clap",            "tag": "exclaim",    "animation": "stamp",          "anchor_landmark": "mid_wrists"},
    {"id": "point_at_camera", "tag": "arrow",      "animation": "slide_in_left",  "anchor_landmark": "right_index"},
    {"id": "pose_static",     "tag": null,         "animation": null,             "anchor_landmark": null},
    {"id": "lean_or_sway",    "tag": null,         "animation": null,             "anchor_landmark": null},
    {"id": "none",            "tag": null,         "animation": null,             "anchor_landmark": null}
  ]
