{
  "_comment": "v10 style presets. `subtitle_default` chooses 'outlined' (純文字+厚描邊, baseline3 vibe), 'banner' (legacy rounded chip), or 'hero' (single huge centred glyph). Override at the CLI with --subtitle-style.",
  "default": "pink_handdrawn",
  "presets": {
    "pink_handdrawn": {
      "subtitle_default": "outlined",
      "text": {
        "color": "#FF6B9D",
        "color_strong": "#E63946",
        "outline_color": "#264653",
        "outline_width": 5,
        "halo_color": "#FFFFFF",
        "halo_width": 4
      },
      "subtitle_outlined": {
        "text_color": "#FFFFFF",
        "outline_color": "#FF6B9D",
        "outline_width": 6,
        "shadow_offset": 2,
        "shadow_alpha": 120,
        "font": "KleeOne-SemiBold"
      },
      "subtitle_banner": {
        "text_color": "#FFFFFF",
        "outline_color": "#E63946",
        "outline_width": 4,
        "bg_color": "#FF6B9D",
        "bg_alpha": 180,
        "corner_radius": 16,
        "padding": 18,
        "font": "KleeOne-SemiBold"
      },
      "decoration_color_palette": ["#FF6B9D", "#FFFFFF", "#E63946"],
      "ambient_tags": ["sparkle", "heart"]
    },
    "green_neon": {
      "subtitle_default": "outlined",
      "text": {
        "color": "#FFFFFF",
        "color_strong": "#FFFFFF",
        "outline_color": "#A0E847",
        "outline_width": 6,
        "halo_color": "#A0E847",
        "halo_width": 4
      },
      "subtitle_outlined": {
        "text_color": "#FFFFFF",
        "outline_color": "#A0E847",
        "outline_width": 7,
        "shadow_offset": 2,
        "shadow_alpha": 100,
        "font": "KleeOne-SemiBold"
      },
      "subtitle_banner": {
        "text_color": "#FFFFFF",
        "outline_color": "#A0E847",
        "outline_width": 6,
        "bg_color": "#A0E847",
        "bg_alpha": 100,
        "corner_radius": 18,
        "padding": 18,
        "font": "KleeOne-SemiBold"
      },
      "decoration_color_palette": ["#FF6B9D", "#A0E847", "#FFFFFF"],
      "ambient_tags": ["sparkle", "star"]
