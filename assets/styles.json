        "color": "#FFFFFF",
        "color_strong": "#FFFFFF",
        "outline_color": "#FF6B9D",
        "outline_width": 7,
        "halo_color": "#FFFFFF",
        "halo_width": 4
      },
      "subtitle_outlined": {
        "text_color": "#FFFFFF",
        "outline_color": "#FF6B9D",
        "outline_color_alt": "#5BBFE3",
        "outline_width": 8,
        "shadow_offset": 3,
        "shadow_alpha": 100,
        "font": "KleeOne-SemiBold"
      },
      "decoration_color_palette": ["#FF6B9D", "#5BBFE3", "#FFFFFF"],
      "ambient_tags": ["sparkle", "heart", "star"]
    }
